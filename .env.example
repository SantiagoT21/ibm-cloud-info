# IBM Cloud Configuration
# Copy this file to .env for local development
# For GitHub Actions, configure these as GitHub Secrets

# IBM Cloud API Key
# Get your API key from: https://cloud.ibm.com/iam/apikeys
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here

# IBM Cloud Region
# Options: us-south, us-east, eu-de, eu-gb, jp-tok, au-syd
IBM_CLOUD_REGION=us-south

# IBM Cloud Resource Group
# The resource group where resources will be created
IBM_CLOUD_RESOURCE_GROUP=Default

# IBM Container Registry Namespace
# Your ICR namespace for storing Docker images
# Create one at: https://cloud.ibm.com/registry/namespaces
ICR_NAMESPACE=your_icr_namespace_here

# ============================================
# GitHub Secrets Configuration
# ============================================
# Add these secrets to your GitHub repository:
# Settings > Secrets and variables > Actions > New repository secret
#
# Required Secrets:
# - IBM_CLOUD_API_KEY
# - IBM_CLOUD_REGION
# - IBM_CLOUD_RESOURCE_GROUP
# - ICR_NAMESPACE
#
# ============================================
# Local Development
# ============================================
# For local Terraform execution:
# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. Source the file: source .env
# 4. Or create terraform/terraform.tfvars from terraform.tfvars.example